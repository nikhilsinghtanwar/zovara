import { NextResponse } from 'next/server';
import { createClient } from '@supabase/supabase-js';

const supabaseUrl = process.env.NEXT_PUBLIC_SUPABASE_URL || '';
const supabaseKey = process.env.SUPABASE_SERVICE_ROLE_KEY || process.env.NEXT_PUBLIC_SUPABASE_ANON_KEY || '';
const supabase = createClient(supabaseUrl, supabaseKey);

// Allowed tables array to protect against SQL injections
const ALLOWED_TABLES = ['packages', 'destinations', 'blog_posts', 'media_gallery', 'team_members'];

function validateTable(table: string) {
  return ALLOWED_TABLES.includes(table);
}

// 1. GET ALL RECORDS DYNAMICALLY
export async function GET(request: Request, { params }: { params: { table: string } }) {
  const { table } = params;
  if (!validateTable(table)) {
    return NextResponse.json({ error: 'Invalid module endpoint' }, { status: 400 });
  }

  const { data, error } = await supabase
    .from(table)
    .select('*')
    .order('created_at', { ascending: false });

  if (error) return NextResponse.json({ error: error.message }, { status: 500 });
  return NextResponse.json(data);
}

// 2. INSERT NEW RECORD DYNAMICALLY
export async function POST(request: Request, { params }: { params: { table: string } }) {
  const { table } = params;
  if (!validateTable(table)) {
    return NextResponse.json({ error: 'Invalid module endpoint' }, { status: 400 });
  }

  try {
    const body = await request.json();
    
    // Automatically generate slug if title/name exists but slug is missing
    if (!body.slug && (body.title || body.name)) {
      body.slug = (body.title || body.name).toLowerCase().replace(/[^a-z0-9]+/g, '-');
    }

    const { data, error } = await supabase
      .from(table)
      .insert([body])
      .select();

    if (error) return NextResponse.json({ error: error.message }, { status: 400 });
    return NextResponse.json(data[0]);
  } catch (err) {
    return NextResponse.json({ error: 'Malformed JSON body input' }, { status: 400 });
  }
}

// 3. DELETE RECORD DYNAMICALLY
export async function DELETE(request: Request, { params }: { params: { table: string } }) {
  const { table } = params;
  if (!validateTable(table)) {
    return NextResponse.json({ error: 'Invalid module endpoint' }, { status: 400 });
  }

  const { searchParams } = new URL(request.url);
  const id = searchParams.get('id');

  if (!id) return NextResponse.json({ error: 'Missing row ID parameter' }, { status: 400 });

  const { error } = await supabase.from(table).delete().eq('id', id);
  if (error) return NextResponse.json({ error: error.message }, { status: 400 });
  
  return NextResponse.json({ success: true, message: `Record deleted from ${table}` });
}